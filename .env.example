# ENTROPIA Environment Configuration
# Thermodynamic Framework for Information Systems

# Application Settings
ENTROPIA_ENV=development
ENTROPIA_DEBUG=true
ENTROPIA_LOG_LEVEL=INFO

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_DEBUG=false

# System Parameters
ENTROPIA_ARCHITECTURE=von_neumann  # von_neumann | neuromorphic | quantum
ENTROPIA_NODE_COUNT=1000000
ENTROPIA_BANDWIDTH=1e12  # bits per second
ENTROPIA_MEMORY_CAPACITY=1e9  # bytes

# Critical Thresholds
ENTROPIA_CRITICAL_PSI=2.0
ENTROPIA_CRITICAL_RHO_RATIO=0.95  # ρ/ρ_c threshold for warning
ENTROPIA_COLLAPSE_LEAD_TIME_MIN=30  # seconds

# Thermodynamic Parameters
ENTROPIA_ALPHA=0.85  # Configurational entropy weight
ENTROPIA_BETA=0.15   # Informational entropy weight
ENTROPIA_SCALING_EXPONENT=1.85  # n for von Neumann architecture
ENTROPIA_ACTIVATION_ENERGY=0.6  # eV

# Simulation Settings
ENTROPIA_SIMULATION_SEED=42
ENTROPIA_SIMULATION_TIMESTEP=0.001  # seconds
ENTROPIA_SIMULATION_DURATION=3600  # seconds

# Data Sources
ENTROPIA_DATA_DIR=/home/entropia/data
ENTROPIA_OUTAGE_DATA_DIR=/home/entropia/data/outages
ENTROPIA_BGP_DATA_DIR=/home/entropia/data/bgp

# API Keys (optional)
# RIPE_NCC_API_KEY=your_key_here
# CAIDA_API_KEY=your_key_here

# Monitoring
ENTROPIA_METRICS_ENABLED=true
ENTROPIA_METRICS_PORT=9090
ENTROPIA_PROFILING_ENABLED=false

# Security
ENTROPIA_SECRET_KEY=change_this_in_production
ENTROPIA_ALLOWED_ORIGINS=http://localhost:8080,https://entropy.netlify.app

# Notification
ENTROPIA_ALERT_WEBHOOK_URL=
ENTROPIA_ALERT_EMAIL=admin@example.com
